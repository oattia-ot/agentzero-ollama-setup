# Copy this file to .env and customize
# docker compose --env-file .env up -d
#
# Every variable here is actually read by docker-compose.yml via ${VAR}
# substitution. Defaults below assume 64GB RAM / 16 cores under WSL2, with
# some headroom left for Windows + other WSL distros:
#   Ollama:      12 cores / 48GB RAM
#   Agent Zero:   4 cores / 12GB RAM
#   Portainer/Watchtower: small fixed limits (set directly in compose)
#
# IMPORTANT (WSL2): these limits are capped by whatever WSL2's own VM is
# allowed to use. See the "WSL2 hardware notes" comment at the top of
# docker-compose.yml — you likely need a .wslconfig on the Windows side
# (memory=56GB, processors=16) for these numbers to actually take effect.

# --- Ollama ---
OLLAMA_KEEP_ALIVE=24h
OLLAMA_CONTEXT_LENGTH=16384
OLLAMA_PORT=11434
OLLAMA_MEM_LIMIT=48g
OLLAMA_CPUS=12
OLLAMA_SHM_SIZE=4gb
# CPU inference tuning
OLLAMA_NUM_THREAD=14
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_MAX_QUEUE=512

# --- Agent Zero ---
AGENT_ZERO_PORT=8080
AGENT_ZERO_MEM_LIMIT=12g
AGENT_ZERO_CPUS=4
AGENT_ZERO_SHM_SIZE=2gb

# --- Watchtower ---
WATCHTOWER_POLL_INTERVAL=3600

# GPU note: this profile is CPU-only. If you have an NVIDIA GPU (with WSL2
# GPU passthrough enabled in Docker Desktop), don't add an OLLAMA_NUM_GPU
# variable — uncomment the deploy.resources GPU block in docker-compose.yml
# instead; that's the mechanism Compose actually uses for GPU passthrough.
